{
    "compilerOptions": {
        // Environment setup & latest features
        "lib": ["ESNext"],
        "target": "ESNext",
        "module": "NodeNext",
        "moduleDetection": "force",
        "moduleResolution": "nodenext",
        "exactOptionalPropertyTypes": true,
        "noEmit": true,

        // Best practices
        "strict": true,
        "skipLibCheck": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedIndexedAccess": true
    }
}
